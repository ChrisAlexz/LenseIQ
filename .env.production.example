# Production .env template for the EC2 deployment.
# Copy to ".env" on the server and fill in the real secret values.
#   cp .env.production.example .env
# This file (the example) is safe to commit; the real .env is gitignored.

# --- Auth ---
# Generate a long random value:  openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_RANDOM_64_HEX
ALLOW_DEV_PRO_ACCESS=1
UNLIMITED_UPLOAD_EMAILS=chrishern869@gmail.com

# --- Database (Postgres runs in the db container) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=lenseiq
DB_USER=lenseiq
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD

# --- URLs (production domain) ---
CORS_ORIGINS=https://lenseiq.vip
FRONTEND_URL=https://lenseiq.vip
# Leave NEXT_PUBLIC_API_URL empty: the browser uses relative URLs that nginx
# routes to the backend. (Set in docker-compose.prod.yml, shown here for clarity.)
NEXT_PUBLIC_API_URL=

# --- AI provider (Gemini) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Transcription (Deepgram) ---
DEEPGRAM_API_KEY=REPLACE_WITH_DEEPGRAM_KEY

# --- Email (SMTP via Gmail app password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=lenseiqsupport@gmail.com
SMTP_PASS=REPLACE_WITH_GMAIL_APP_PASSWORD
